#!/usr/bin/env bash
# commit-quotes — commit and push changes to quotes.txt in the wisdom repo

# - Only ever touches quotes.txt; all other staged/unstaged changes preserved
# - Generates a descriptive commit message from the diff when possible
# - Pushes only if github.com:443 is reachable within 3 seconds
# - Always exits 0 so cron never sends mail
#
# Usage: bin/commit-quotes          (from anywhere — path or symlink)
#        make commit_quotes

# BASH_SOURCE[0] is always this script's path, regardless of cwd or $0.
# cd to its directory, then let git walk up to find the repo root.
# This works whether called as bin/commit-quotes, ~/bin/commit-quotes, or from cron.
REPO_ROOT_DIR=$(CDPATH='' cd "$(dirname "${BASH_SOURCE[0]}")" && git rev-parse --show-toplevel)
LOG="$REPO_ROOT_DIR/logs/commit-quotes.log"
mkdir -p "$REPO_ROOT_DIR/logs"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S')  $*" >> "$LOG"; }

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
main() {
    set -euo pipefail
    cd "$REPO_ROOT_DIR"

    # Nothing to do if quotes.txt is clean (no staged or unstaged changes).
    if git diff --quiet quotes.txt && git diff --cached --quiet quotes.txt; then
        exit 0
    fi

    # If OTHER files are currently staged, stash them so they stay out of
    # this commit and are restored exactly as found afterwards.
    local stashed=0
    if ! git diff --cached --quiet ':!quotes.txt' 2>/dev/null; then
        git stash push --staged -m "commit-quotes: preserving staged changes"
        stashed=1
        log "Stashed other staged changes."
    fi

    git add quotes.txt

    # Guard: if a staged addition and an unstaged revert of the same lines
    # were both present, staging quotes.txt cancels them out — nothing to commit.
    if git diff --cached --quiet; then
        (( stashed )) && git stash pop
        exit 0
    fi

    local msg
    msg=$(generate_message)
    git commit -m "$msg"
    log "Committed: $msg"

    (( stashed )) && git stash pop && log "Restored stashed changes."

    # nc -z  = probe only, send no data
    # nc -w 3 = abandon after 3 seconds
    # Tests port 443 (HTTPS) on github.com; /usr/bin/nc avoids $PATH surprises in cron.
    if /usr/bin/nc -z -w 3 github.com 443 2>/dev/null; then
        git push
        log "Pushed."
    else
        log "Offline — push skipped."
    fi
}

# ---------------------------------------------------------------------------
# generate_message — parse staged diff, return human-readable commit message
# ---------------------------------------------------------------------------
generate_message() {
    git diff --cached quotes.txt | awk -f <(_awk_quote_parser)
}

# ===========================================================================
# _awk_quote_parser — emit the awk program that extracts author + first line
# from a unified diff of quotes.txt.
#
# Prints one of:
#   Add quote by Author: "First line..."
#   Add N quotes (first by Author: "First line...")
#   Add N quotes
#   Update quotes.txt                        (edits, no new blocks found)
# ===========================================================================
_awk_quote_parser() {
    cat <<'AWKEOF'
BEGIN {
    in_block    = 0
    first_line  = ""
    author      = ""
    block_count = 0
    saved_first = ""
    saved_author = ""
}

# A separator line in the added (+) side opens a new quote block.
# When we hit one, close out the previous block if it had content.
/^\+={8,}/ {
    if (in_block && first_line != "") {
        block_count++
        if (block_count == 1) { saved_first = first_line; saved_author = author }
    }
    in_block   = 1
    first_line = ""
    author     = ""
    next
}

/^-/      { next }   # removed lines — ignore
!in_block { next }   # context lines outside a block — ignore

/^\+/ {
    line = substr($0, 2)                                   # strip leading +
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)          # trim whitespace
    if (line == "") next

    # Attribution line: "  -- Name" or "-- Name"
    if (line ~ /^--[[:space:]]/ || line ~ /^[[:space:]]+--[[:space:]]/) {
        sub(/^[[:space:]]*--[[:space:]]*/, "", line)
        author = line
        next
    }

    # First content line of this block
    if (first_line == "") {
        first_line = substr(line, 1, 60)
        if (length(line) > 60) first_line = first_line "..."
    }
}

END {
    # Close out the final open block
    if (in_block && first_line != "") {
        block_count++
        if (block_count == 1) { saved_first = first_line; saved_author = author }
    }

    if (block_count == 0) {
        print "Update quotes.txt"
    } else if (block_count == 1) {
        if (saved_author != "")
            printf "Add quote by %s: \"%s\"\n", saved_author, saved_first
        else
            printf "Add quote: \"%s\"\n", saved_first
    } else {
        if (saved_author != "")
            printf "Add %d quotes (first by %s: \"%s\")\n", block_count, saved_author, saved_first
        else
            printf "Add %d quotes\n", block_count
    }
}
AWKEOF
}

# ---------------------------------------------------------------------------
# Top-level safety net: log any unexpected error, always exit 0 (no cron mail)
# ---------------------------------------------------------------------------
trap 'status=$?; log "ERROR (exit $status) at line $LINENO"; exit 0' ERR

main "$@"
