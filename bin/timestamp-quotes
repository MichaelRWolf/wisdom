#!/usr/bin/perl
use strict;
use warnings;
use POSIX qw(strftime);

die "Usage: $0 <file>\n" unless @ARGV == 1;

my $today = strftime("%Y-%m-%d", localtime);

$^I = "";

# Standard separator created in Emacs (64 '='s)
#    C-u C-u C-u '='
#
# "Short" separator (16 '='s)
#    C-u C-u '='

my $hline_length_standard = (4**3);
my $hline_length_short = $hline_length_standard / 2 ;
my $hline_length_standard_min = $hline_length_short+1;

my $hline_standard = '=' x $hline_length_standard;

my $seen_hline_with_timestamp = 0;

 LINE:
while (my $line = <ARGV>) {
    if ($seen_hline_with_timestamp) { print $line; next LINE }

  LINE_SWITCH:
    for ($line) {

	# First hline WITH timestamp - output it, then allow remaining lines to pass unchanged
        /^(={$hline_length_standard_min,})\s+(\d{4}-\d{2}-\d{2})(.*)/ and do { 
	    $seen_hline_with_timestamp = 1;

	    print "$hline_standard $2$3\n"; 
	    last LINE_SWITCH;
	};
	
	# hline WITHOUT tiestamp - output it WITH timestamp
        /^(={$hline_length_standard_min,})\s*$/ and do {

	    print "$hline_standard $today\n";  
	    last LINE_SWITCH;
	};
	
	# Default
        print;
    }
}
